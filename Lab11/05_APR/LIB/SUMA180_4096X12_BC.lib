  pin(CK) {
    direction : input ;      
    capacitance : 0.0600;
    max_transition : 2.0;
    clock : true;
    timing() {
      related_pin : "CK";
      timing_type : min_pulse_width;
      rise_constraint(SUMA180_4096X12_2) {
        values("0.2524,0.3197,0.3386,0.3401,0.3322");
      }
      fall_constraint(SUMA180_4096X12_2) {
        values("0.2524,0.3197,0.3386,0.3401,0.3322");
      }
    }
    timing() {
      related_pin : "CK";
      timing_type : minimum_period;
      rise_constraint(SUMA180_4096X12_2) {
        values("1.8299,1.8021,1.7830,1.7830,1.7830");
      }
      fall_constraint(SUMA180_4096X12_2) {
        values("1.8299,1.8021,1.7830,1.7830,1.7830");
      }
    }

    internal_power () {
      when : "CS WEB";
      rise_power(POWER_3x1) {
        values("330.8521,330.8521,330.8521"); /* pW/HZ */
      }
      fall_power(POWER_3x1) {
        values("0,0,0"); /* pW/HZ */
      }      
    }
    internal_power () {
      when : "CS !WEB";
      rise_power(POWER_3x1) {
        values("330.8521,330.8521,330.8521"); /* pW/HZ */
      }
      fall_power(POWER_3x1) {
