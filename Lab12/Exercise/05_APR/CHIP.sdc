###################################################################

# Created by write_sdc on Wed May 27 15:52:37 2026

###################################################################
set sdc_version 2.1

set_units -time ns -resistance kOhm -capacitance pF -voltage V -current mA
#set_wire_load_mode top
#set_wire_load_model -name enG500K -library fsa0m_a_generic_core_ss1p62v125c
set_load -pin_load 0.05 [get_ports o_valid]
set_load -pin_load 0.05 [get_ports {o_data[7]}]
set_load -pin_load 0.05 [get_ports {o_data[6]}]
set_load -pin_load 0.05 [get_ports {o_data[5]}]
set_load -pin_load 0.05 [get_ports {o_data[4]}]
set_load -pin_load 0.05 [get_ports {o_data[3]}]
set_load -pin_load 0.05 [get_ports {o_data[2]}]
set_load -pin_load 0.05 [get_ports {o_data[1]}]
set_load -pin_load 0.05 [get_ports {o_data[0]}]
set_max_capacitance 0.15 [get_ports clk]
set_max_capacitance 0.15 [get_ports rst_n]
set_max_capacitance 0.15 [get_ports i_valid]
set_max_capacitance 0.15 [get_ports {i_iter[2]}]
set_max_capacitance 0.15 [get_ports {i_iter[1]}]
set_max_capacitance 0.15 [get_ports {i_iter[0]}]
set_max_capacitance 0.15 [get_ports {i_mode[1]}]
set_max_capacitance 0.15 [get_ports {i_mode[0]}]
set_max_capacitance 0.15 [get_ports {i_data[7]}]
set_max_capacitance 0.15 [get_ports {i_data[6]}]
set_max_capacitance 0.15 [get_ports {i_data[5]}]
set_max_capacitance 0.15 [get_ports {i_data[4]}]
set_max_capacitance 0.15 [get_ports {i_data[3]}]
set_max_capacitance 0.15 [get_ports {i_data[2]}]
set_max_capacitance 0.15 [get_ports {i_data[1]}]
set_max_capacitance 0.15 [get_ports {i_data[0]}]
set_max_capacitance 0.15 [get_ports {i_weight[3]}]
set_max_capacitance 0.15 [get_ports {i_weight[2]}]
set_max_capacitance 0.15 [get_ports {i_weight[1]}]
set_max_capacitance 0.15 [get_ports {i_weight[0]}]
set_max_fanout 10 [get_ports clk]
set_max_fanout 10 [get_ports rst_n]
set_max_fanout 10 [get_ports i_valid]
set_max_fanout 10 [get_ports {i_iter[2]}]
set_max_fanout 10 [get_ports {i_iter[1]}]
set_max_fanout 10 [get_ports {i_iter[0]}]
set_max_fanout 10 [get_ports {i_mode[1]}]
set_max_fanout 10 [get_ports {i_mode[0]}]
set_max_fanout 10 [get_ports {i_data[7]}]
set_max_fanout 10 [get_ports {i_data[6]}]
set_max_fanout 10 [get_ports {i_data[5]}]
set_max_fanout 10 [get_ports {i_data[4]}]
set_max_fanout 10 [get_ports {i_data[3]}]
set_max_fanout 10 [get_ports {i_data[2]}]
set_max_fanout 10 [get_ports {i_data[1]}]
set_max_fanout 10 [get_ports {i_data[0]}]
set_max_fanout 10 [get_ports {i_weight[3]}]
set_max_fanout 10 [get_ports {i_weight[2]}]
set_max_fanout 10 [get_ports {i_weight[1]}]
set_max_fanout 10 [get_ports {i_weight[0]}]
set_max_transition 3 [get_ports clk]
set_max_transition 3 [get_ports rst_n]
set_max_transition 3 [get_ports i_valid]
set_max_transition 3 [get_ports {i_iter[2]}]
set_max_transition 3 [get_ports {i_iter[1]}]
set_max_transition 3 [get_ports {i_iter[0]}]
set_max_transition 3 [get_ports {i_mode[1]}]
set_max_transition 3 [get_ports {i_mode[0]}]
set_max_transition 3 [get_ports {i_data[7]}]
set_max_transition 3 [get_ports {i_data[6]}]
set_max_transition 3 [get_ports {i_data[5]}]
set_max_transition 3 [get_ports {i_data[4]}]
set_max_transition 3 [get_ports {i_data[3]}]
set_max_transition 3 [get_ports {i_data[2]}]
set_max_transition 3 [get_ports {i_data[1]}]
set_max_transition 3 [get_ports {i_data[0]}]
set_max_transition 3 [get_ports {i_weight[3]}]
set_max_transition 3 [get_ports {i_weight[2]}]
set_max_transition 3 [get_ports {i_weight[1]}]
set_max_transition 3 [get_ports {i_weight[0]}]
create_clock [get_ports clk]  -period 20  -waveform {0 10}
set_clock_uncertainty 0.1  [get_clocks clk]
set_clock_transition -max -rise 0.1 [get_clocks clk]
set_clock_transition -max -fall 0.1 [get_clocks clk]
set_clock_transition -min -rise 0.1 [get_clocks clk]
set_clock_transition -min -fall 0.1 [get_clocks clk]
set_input_delay -clock clk  0  [get_ports clk]
set_input_delay -clock clk  0  [get_ports rst_n]
set_input_delay -clock clk  -max 10  [get_ports i_valid]
set_input_delay -clock clk  -min 0  [get_ports i_valid]
set_input_delay -clock clk  -max 10  [get_ports {i_iter[2]}]
set_input_delay -clock clk  -min 0  [get_ports {i_iter[2]}]
set_input_delay -clock clk  -max 10  [get_ports {i_iter[1]}]
set_input_delay -clock clk  -min 0  [get_ports {i_iter[1]}]
set_input_delay -clock clk  -max 10  [get_ports {i_iter[0]}]
set_input_delay -clock clk  -min 0  [get_ports {i_iter[0]}]
set_input_delay -clock clk  -max 10  [get_ports {i_mode[1]}]
set_input_delay -clock clk  -min 0  [get_ports {i_mode[1]}]
set_input_delay -clock clk  -max 10  [get_ports {i_mode[0]}]
set_input_delay -clock clk  -min 0  [get_ports {i_mode[0]}]
set_input_delay -clock clk  -max 10  [get_ports {i_data[7]}]
set_input_delay -clock clk  -min 0  [get_ports {i_data[7]}]
set_input_delay -clock clk  -max 10  [get_ports {i_data[6]}]
set_input_delay -clock clk  -min 0  [get_ports {i_data[6]}]
set_input_delay -clock clk  -max 10  [get_ports {i_data[5]}]
set_input_delay -clock clk  -min 0  [get_ports {i_data[5]}]
set_input_delay -clock clk  -max 10  [get_ports {i_data[4]}]
set_input_delay -clock clk  -min 0  [get_ports {i_data[4]}]
set_input_delay -clock clk  -max 10  [get_ports {i_data[3]}]
set_input_delay -clock clk  -min 0  [get_ports {i_data[3]}]
