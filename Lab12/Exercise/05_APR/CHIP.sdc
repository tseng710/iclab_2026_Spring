set_input_delay -clock clk  -max 10  [get_ports {i_weight[3]}]
set_input_delay -clock clk  -min 0  [get_ports {i_weight[3]}]
set_input_delay -clock clk  -max 10  [get_ports {i_weight[2]}]
set_input_delay -clock clk  -min 0  [get_ports {i_weight[2]}]
set_input_delay -clock clk  -max 10  [get_ports {i_weight[1]}]
set_input_delay -clock clk  -min 0  [get_ports {i_weight[1]}]
set_input_delay -clock clk  -max 10  [get_ports {i_weight[0]}]
set_input_delay -clock clk  -min 0  [get_ports {i_weight[0]}]
set_output_delay -clock clk  -max 10  [get_ports o_valid]
set_output_delay -clock clk  -min 0  [get_ports o_valid]
set_output_delay -clock clk  -max 10  [get_ports {o_data[7]}]
set_output_delay -clock clk  -min 0  [get_ports {o_data[7]}]
set_output_delay -clock clk  -max 10  [get_ports {o_data[6]}]
set_output_delay -clock clk  -min 0  [get_ports {o_data[6]}]
set_output_delay -clock clk  -max 10  [get_ports {o_data[5]}]
set_output_delay -clock clk  -min 0  [get_ports {o_data[5]}]
set_output_delay -clock clk  -max 10  [get_ports {o_data[4]}]
set_output_delay -clock clk  -min 0  [get_ports {o_data[4]}]
set_output_delay -clock clk  -max 10  [get_ports {o_data[3]}]
set_output_delay -clock clk  -min 0  [get_ports {o_data[3]}]
set_output_delay -clock clk  -max 10  [get_ports {o_data[2]}]
set_output_delay -clock clk  -min 0  [get_ports {o_data[2]}]
set_output_delay -clock clk  -max 10  [get_ports {o_data[1]}]
set_output_delay -clock clk  -min 0  [get_ports {o_data[1]}]
set_output_delay -clock clk  -max 10  [get_ports {o_data[0]}]
set_output_delay -clock clk  -min 0  [get_ports {o_data[0]}]
set_input_transition -max 0.5  [get_ports clk]
set_input_transition -min 0.5  [get_ports clk]
set_input_transition -max 0.5  [get_ports rst_n]
set_input_transition -min 0.5  [get_ports rst_n]
