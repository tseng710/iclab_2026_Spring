    wire [3:0] oy = pixel_cnt[7:4];
    reg [1:0] kx, ky;
    always @(*) begin
        case (step_cnt)
            0: begin kx = 0; ky = 0; end 
            1: begin kx = 1; ky = 0; end 
            2: begin kx = 2; ky = 0; end
            3: begin kx = 0; ky = 1; end 
            4: begin kx = 1; ky = 1; end 
            5: begin kx = 2; ky = 1; end
            6: begin kx = 0; ky = 2; end 
            7: begin kx = 1; ky = 2; end 
            8: begin kx = 2; ky = 2; end
            default: begin kx = 0; ky = 0; end
        endcase
    end

    wire signed [6:0] ix_dn = $signed({1'b0, ox, 2'b00}) + kx - 1;
    wire signed [6:0] iy_dn = $signed({1'b0, oy, 2'b00}) + ky - 1;
    wire valid_dn = (ix_dn >= 0 && ix_dn < 64 && iy_dn >= 0 && iy_dn < 64);
    wire [11:0] img_pixel_idx = iy_dn * 64 + ix_dn; 

    wire signed [5:0] ix_up = $signed({2'b0, ox}) + kx - 1;
    wire signed [5:0] iy_up = $signed({2'b0, oy}) + ky - 1;
    wire valid_up = (ix_up >= 0 && ix_up < 16 && iy_up >= 0 && iy_up < 16);
    wire [7:0] up_addr = iy_up * 16 + ix_up;

    wire [3:0] X_blk = w_cnt[3:0]; 
    wire [5:0] Y_blk = w_cnt[9:4];
    wire [1:0] dy_interp = w_cnt[5:4]; 
    wire [3:0] Y_blk_real = w_cnt[9:6];
    
    wire [3:0] read_X_A = (saved_mode == 1 && X_blk == 15) ? 4'd14 : X_blk;
    wire [3:0] read_X_B = (saved_mode == 1 && X_blk == 15) ? 4'd15 : ((saved_mode == 1) ? X_blk + 1 : X_blk);
    wire [3:0] read_Y_A = (saved_mode == 2 && Y_blk_real == 15) ? 4'd14 : Y_blk_real;
    wire [3:0] read_Y_B = (saved_mode == 2 && Y_blk_real == 15) ? 4'd15 : ((saved_mode == 2) ? Y_blk_real + 1 : Y_blk_real);
    
    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            valid_dn_d1 <= 0; valid_dn_d2 <= 0; valid_dn_d3 <= 0;
            valid_up_d1 <= 0; valid_up_d2 <= 0; valid_up_d3 <= 0;
            img_idx_d1 <= 0;  img_idx_d2 <= 0;
        end else begin
            valid_dn_d1 <= valid_dn; valid_dn_d2 <= valid_dn_d1; valid_dn_d3 <= valid_dn_d2;
            valid_up_d1 <= valid_up; valid_up_d2 <= valid_up_d1; valid_up_d3 <= valid_up_d2;
            img_idx_d1 <= img_pixel_idx; img_idx_d2 <= img_idx_d1;
        end
    end

    // ========================================================================
    // 6. 🔥 MULTIPLIER ARRAY 1 (Shared: QKV / FFN / CONV / ATTN Score)
    // ========================================================================
    reg [7:0] current_img_pixel;
    always @(*) begin
        if (valid_dn_d2) begin
            case (img_idx_d2[1:0])
                2'b00: current_img_pixel = img_DO[7:0];   2'b01: current_img_pixel = img_DO[15:8];
                2'b10: current_img_pixel = img_DO[23:16]; 2'b11: current_img_pixel = img_DO[31:24];
            endcase
        end else current_img_pixel = 8'd0;
    end

    reg signed [8:0] A1 [0:15][0:15];
    reg signed [8:0] B1 [0:15][0:15];
    
    always @(*) begin
        for(i=0; i<16; i=i+1) for(j=0; j<16; j=j+1) begin A1[i][j] = 0; B1[i][j] = 0; end
        
        if (state == S_QKV) begin
            if (step_cnt == 3) begin
                for(i=0; i<16; i=i+1) for(j=0; j<16; j=j+1) begin
                    A1[i][j] = $signed({1'b0, X_reg[j*8+:8]}) - 9'sd128; B1[i][j] = w_q[j][i];
                end
            end else if (step_cnt == 5) begin
                for(i=0; i<16; i=i+1) for(j=0; j<16; j=j+1) begin
                    A1[i][j] = $signed({1'b0, X_reg[j*8+:8]}) - 9'sd128; B1[i][j] = w_k[j][i];
                end
            end else if (step_cnt == 7) begin
                for(i=0; i<16; i=i+1) for(j=0; j<16; j=j+1) begin
                    A1[i][j] = $signed({1'b0, X_reg[j*8+:8]}) - 9'sd128; B1[i][j] = w_v[j][i];
                end
            end
        end
        else if (state == S_FFN) begin
            if (step_cnt == 3) begin
                for(i=0; i<16; i=i+1) for(j=0; j<16; j=j+1) begin
                    A1[i][j] = $signed(X_reg[j*8+:8]); B1[i][j] = w_ffn[j][i];
                end
            end
        end
        else if (state == S_ATTN) begin
            if (step_cnt >= 19 && step_cnt <= 274) begin
                for(i=0; i<16; i=i+1) for(j=0; j<16; j=j+1) begin
                    A1[i][j] = $signed(attn_Q_buf[i][j*8+:8]); B1[i][j] = $signed(K_data_reg[j*8+:8]);
                end
            end
        end
        else if (state == S_CONV_DOWN) begin
            if (step_cnt >= 2 && step_cnt <= 10) begin
                for(i=0; i<16; i=i+1) begin
                    A1[i][0] = $signed({1'b0, current_img_pixel}); B1[i][0] = w_conv_dn[i][0];
                end
            end
        end
        else if (state == S_CONV_UP) begin
            if (step_cnt >= 2 && step_cnt <= 10) begin
                for(j=0; j<16; j=j+1) begin
                    A1[0][j] = $signed({1'b0, fmB_DO[j*8+:8]}); B1[0][j] = w_conv_up[j][0];
                end
            end
        end
    end

    wire signed [17:0] P1_comb [0:15][0:15];
    generate
        for(gi=0; gi<16; gi=gi+1) begin : gen_P1
            for(gj=0; gj<16; gj=gj+1) begin : gen_P1_mult
                assign P1_comb[gi][gj] = A1[gi][gj] * B1[gi][gj];
            end
        end
    endgenerate

    always @(posedge clk) begin
        for(i=0; i<16; i=i+1) for(j=0; j<16; j=j+1) P1_reg[i][j] <= P1_comb[i][j];
    end

    wire signed [21:0] Tree1_out [0:15];
    generate
        for(gi=0; gi<16; gi=gi+1) begin : gen_Tree1
            wire signed [18:0] sum1 [0:7];
            wire signed [19:0] sum2 [0:3];
            wire signed [20:0] sum3 [0:1];
            for(gj=0; gj<8; gj=gj+1) assign sum1[gj] = P1_reg[gi][2*gj] + P1_reg[gi][2*gj+1];
            for(gj=0; gj<4; gj=gj+1) assign sum2[gj] = sum1[2*gj] + sum1[2*gj+1];
            for(gj=0; gj<2; gj=gj+1) assign sum3[gj] = sum2[2*gj] + sum2[2*gj+1];
            assign Tree1_out[gi] = sum3[0] + sum3[1];
        end
    endgenerate

    // ----------------------------------------------------
    // QKV / FFN / ATTN Score Clipping & Scaling
    // ----------------------------------------------------
    wire [127:0] comb_qkv_data, comb_ffn_data;
    wire [7:0] comb_fixed [0:15];
    generate
        for(gi=0; gi<16; gi=gi+1) begin : gen_shared_out
            wire signed [21:0] shift_qkv = Tree1_out[gi] >>> 4;
            assign comb_qkv_data[gi*8+:8] = (shift_qkv > 22'sd127) ? 8'd127 : ((shift_qkv < -22'sd128) ? -8'd128 : shift_qkv[7:0]);
            
            wire signed [21:0] norm_f = (Tree1_out[gi] >>> 4) + 22'sd128;
            assign comb_ffn_data[gi*8+:8] = (norm_f > 22'sd255) ? 8'd255 : ((norm_f < 22'sd0) ? 8'd0 : norm_f[7:0]);
            
            wire signed [21:0] sc_div = Tree1_out[gi] >>> 2;
            wire signed [21:0] cl = (sc_div > 22'sd2047) ? 22'sd2047 : ((sc_div < -20'sd2048) ? -20'sd2048 : sc_div);
            assign comb_fixed[gi] = (cl >>> 4) + 22'sd128;
        end
    endgenerate

    reg [7:0] out_clip_array [0:15];
    always @(*) begin
        for (i = 0; i < 16; i = i + 1) begin
            if ((($signed(mac_acc[i]) >>> 6) + 20'sd128) < 20'sd0)        out_clip_array[i] = 8'd0;
            else if ((($signed(mac_acc[i]) >>> 6) + 20'sd128) > 20'sd255) out_clip_array[i] = 8'd255;
            else out_clip_array[i] = (($signed(mac_acc[i]) >>> 6) + 20'sd128);
        end
    end

    // ========================================================================
    // 7. 🔥 MULTIPLIER ARRAY 2 (Dedicated: ATTN V Accumulation)
    // ========================================================================
    wire signed [8:0] A2 [0:15];
    wire signed [8:0] B2 [0:15];
    
    generate
        for(gi=0; gi<16; gi=gi+1) assign A2[gi] = $signed({1'b0, fixed_reg[gi]});
        for(gj=0; gj<16; gj=gj+1) assign B2[gj] = $signed(V_d2[gj*8+:8]);
        
        for(gi=0; gi<16; gi=gi+1) begin : gen_P2_rows
            for(gj=0; gj<16; gj=gj+1) begin : gen_P2_cols
                wire signed [17:0] p2_comb = A2[gi] * B2[gj];
                always @(posedge clk) P2_reg[gi][gj] <= p2_comb;
            end
        end
    endgenerate

    // --- INTERP LOGIC ---
    reg [7:0] out_word_comb [0:3];
    reg signed [9:0] signed_diff; 
    wire signed [9:0] step_val = signed_diff >>> 2;
    wire signed [11:0] base_val = ((saved_mode == 1 && X_blk == 15) || (saved_mode == 2 && Y_blk_real == 15)) ? $signed({1'b0, val_B}) : $signed({1'b0, val_A});
    reg signed [11:0] interp_val; 
    reg [7:0] interp_clip; 
    reg signed [9:0] denoise_val; 
    reg [7:0] denoise_clip;
    
    always @(*) begin
        signed_diff = $signed({1'b0, val_B}) - $signed({1'b0, val_A});
        for (i = 0; i < 4; i = i + 1) begin
            if (saved_mode == 0) interp_val = base_val;
            else if (saved_mode == 1) begin
                if (i == 0) interp_val = base_val; else if (i == 1) interp_val = base_val + step_val;
                else if (i == 2) interp_val = base_val + step_val * 2; else interp_val = base_val + step_val * 3;
            end else begin
                if (dy_interp == 0) interp_val = base_val; else if (dy_interp == 1) interp_val = base_val + step_val;
                else if (dy_interp == 2) interp_val = base_val + step_val * 2; else interp_val = base_val + step_val * 3;
            end
            
            if (interp_val < 12'sd0) interp_clip = 0; else if (interp_val > 12'sd255) interp_clip = 255; else interp_clip = interp_val[7:0];
            denoise_val = $signed({1'b0, orig_word[i*8 +: 8]}) - $signed({1'b0, interp_clip[7:3]});
            if (denoise_val < 10'sd0) denoise_clip = 0; else if (denoise_val > 10'sd255) denoise_clip = 255; else denoise_clip = denoise_val[7:0];
            out_word_comb[i] = denoise_clip;
        end
    end

    // ==========================================
    // 8. Master Control FSM (WITH Asynchronous Reset)
    // ==========================================
    always @(*) begin
        next_state = state;
        case (state)
            S_IDLE:      if (i_valid) next_state = weight_loaded ? S_LOAD_IMG : S_LOAD_W;
            S_LOAD_W:    if (load_cnt == 1312) next_state = S_IDLE;
            S_LOAD_IMG:  if (load_cnt == 4096) next_state = S_CONV_DOWN;
            S_CONV_DOWN: if (pixel_cnt == 255 && step_cnt == 13) next_state = S_QKV;
            S_QKV:       if (pixel_cnt == 255 && step_cnt == 10) next_state = S_ATTN;  
            S_ATTN:      if (attn_pass == 15 && step_cnt == 294) next_state = S_FFN;   
            S_FFN:       if (pixel_cnt == 255 && step_cnt == 6)  next_state = S_CONV_UP;                  
            S_CONV_UP:   if (pixel_cnt == 255 && step_cnt == 13) next_state = S_INTERP;
            S_INTERP:    if (w_cnt == 1023 && step_cnt == 7) next_state = S_NEXT_ITER;
            S_NEXT_ITER: if (current_iter == target_iter) next_state = S_IDLE; else next_state = S_CONV_DOWN;
            default: next_state = S_IDLE;
        endcase
    end

    always @(posedge clk or negedge rst_n) begin
        if (!rst_n) begin
            state <= S_IDLE; o_valid <= 0; o_data <= 0; 
            step_cnt <= 0; pixel_cnt <= 0; load_cnt <= 0; w_cnt <= 0;
            img_pack_cnt <= 0; w_ch <= 0; w_idx <= 0; attn_pass <= 0;
            img_A <= 0; fmA_A <= 0; fmB_A <= 0;
            img_WEB <= 1; fmA_WEB <= 1; fmB_WEB <= 1;
            weight_loaded <= 0; target_iter <= 0; current_iter <= 0; saved_mode <= 0;
        end else begin
            state <= next_state;
            img_WEB <= 1; fmA_WEB <= 1; fmB_WEB <= 1; 
            o_valid <= 0; o_data <= 0;

            case (state)
                S_IDLE: begin
                    step_cnt <= 0; pixel_cnt <= 0; w_cnt <= 0; attn_pass <= 0;
                    if (i_valid) begin
                        if (!weight_loaded) begin load_cnt <= 1; w_ch <= 0; w_idx <= 1; end 
                        else begin target_iter <= i_iter; saved_mode <= i_mode; current_iter <= 1; img_pack_cnt <= 1; img_A <= 0; load_cnt <= 1; end
                    end else load_cnt <= 0;
                end
                
                S_LOAD_W: begin
                    if (i_valid) begin
                        if (w_idx == (load_cnt<144||load_cnt>=1168 ? 8 : 15)) begin w_idx <= 0; w_ch <= w_ch + 1; end else w_idx <= w_idx + 1;
                        if (load_cnt==143 || load_cnt==399 || load_cnt==655 || load_cnt==911 || load_cnt==1167) begin w_ch <= 0; w_idx <= 0; end
                        load_cnt <= load_cnt + 1;
                        if (load_cnt == 1311) weight_loaded <= 1;
                    end
                end
                
                S_LOAD_IMG: begin
                    if (i_valid) begin
                        load_cnt <= load_cnt + 1; img_pack_cnt <= img_pack_cnt + 1;
                        if (img_pack_cnt == 3) begin img_WEB <= 0; img_pack_cnt <= 0; if (load_cnt > 3) img_A <= img_A + 1; end
                    end
                end

                S_CONV_DOWN: begin
                    if (step_cnt < 9 && valid_dn) img_A <= img_pixel_idx[11:2];
                    if (step_cnt == 12) begin fmA_WEB <= 0; fmA_A <= pixel_cnt[8:0]; end
                    if (step_cnt == 13) begin step_cnt <= 0; pixel_cnt <= (pixel_cnt == 255) ? 0 : pixel_cnt + 1; end 
                    else step_cnt <= step_cnt + 1;
                end

                S_QKV: begin
                    if (step_cnt == 0) begin fmA_A <= pixel_cnt[8:0]; step_cnt <= 1; end
                    else if (step_cnt == 1) step_cnt <= 2;
                    else if (step_cnt == 2) step_cnt <= 3;
                    else if (step_cnt == 3) step_cnt <= 4;
                    else if (step_cnt == 4) step_cnt <= 5;
                    else if (step_cnt == 5) begin fmB_WEB <= 0; fmB_A <= pixel_cnt[8:0]; step_cnt <= 6; end
                    else if (step_cnt == 6) step_cnt <= 7;
                    else if (step_cnt == 7) begin fmB_WEB <= 0; fmB_A <= 9'd256 + pixel_cnt[8:0]; step_cnt <= 8; end
                    else if (step_cnt == 8) step_cnt <= 9;
                    else if (step_cnt == 9) begin fmA_WEB <= 0; fmA_A <= 9'd256 + pixel_cnt[8:0]; step_cnt <= 10; end
                    else if (step_cnt == 10) begin step_cnt <= 0; pixel_cnt <= (pixel_cnt == 255) ? 0 : pixel_cnt + 1; end
                end

                S_ATTN: begin
                    if (step_cnt < 16) fmB_A <= attn_pass * 16 + step_cnt;
                    if (step_cnt >= 16 && step_cnt <= 271) begin
                        fmB_A <= 9'd256 + (step_cnt - 16); fmA_A <= 9'd256 + (step_cnt - 16);
                    end
                    if (step_cnt >= 278 && step_cnt <= 293) begin
                        fmA_WEB <= 0; fmA_A <= attn_pass * 16 + (step_cnt - 278);
                    end
                    if (step_cnt == 294) begin step_cnt <= 0; attn_pass <= attn_pass + 1; end 
                    else step_cnt <= step_cnt + 1;
                end

                S_FFN: begin
                    if (step_cnt == 0) begin fmA_A <= pixel_cnt[8:0]; step_cnt <= 1; end
                    else if (step_cnt == 1) step_cnt <= 2;
                    else if (step_cnt == 2) step_cnt <= 3;
                    else if (step_cnt == 3) step_cnt <= 4;
                    else if (step_cnt == 4) step_cnt <= 5;
                    else if (step_cnt == 5) begin fmB_WEB <= 0; fmB_A <= pixel_cnt[8:0]; step_cnt <= 6; end
                    else if (step_cnt == 6) begin step_cnt <= 0; pixel_cnt <= (pixel_cnt == 255) ? 0 : pixel_cnt + 1; end
                end

                S_CONV_UP: begin
                    if (step_cnt < 9 && valid_up) fmB_A <= {1'b0, up_addr};
                    if (step_cnt == 12) begin fmA_WEB <= 0; fmA_A <= 256 + pixel_cnt[8:0]; end
                    if (step_cnt == 13) begin step_cnt <= 0; pixel_cnt <= (pixel_cnt == 255) ? 0 : pixel_cnt + 1; end 
                    else step_cnt <= step_cnt + 1;
                end

                S_INTERP: begin
                    if (step_cnt == 0) begin img_WEB <= 1; img_A <= w_cnt; fmA_WEB <= 1; fmA_A <= 256 + {5'b0, read_Y_A} * 16 + {5'b0, read_X_A}; step_cnt <= 1; end
                    else if (step_cnt == 1) begin fmA_WEB <= 1; fmA_A <= 256 + {5'b0, read_Y_B} * 16 + {5'b0, read_X_B}; step_cnt <= 2; end
                    else if (step_cnt == 2) step_cnt <= 3; 
                    else if (step_cnt == 3) step_cnt <= 4; 
                    else if (step_cnt == 4) begin
                        img_WEB <= 0; img_A <= w_cnt; 
                        if (current_iter == target_iter) begin o_valid <= 1; o_data <= out_word_comb[0]; end
                        step_cnt <= 5;
                    end
                    else if (step_cnt == 5) begin if (current_iter == target_iter) begin o_valid <= 1; o_data <= out_word_reg[15:8]; end step_cnt <= 6; end
                    else if (step_cnt == 6) begin if (current_iter == target_iter) begin o_valid <= 1; o_data <= out_word_reg[23:16]; end step_cnt <= 7; end
                    else if (step_cnt == 7) begin
                        if (current_iter == target_iter) begin o_valid <= 1; o_data <= out_word_reg[31:24]; end
                        step_cnt <= 0; if (w_cnt != 1023) w_cnt <= w_cnt + 1;
                    end
                end
                
                S_NEXT_ITER: begin
                    if (current_iter != target_iter) begin current_iter <= current_iter + 1; pixel_cnt <= 0; step_cnt <= 0; w_cnt <= 0; attn_pass <= 0; end
                end
            endcase
        end
    end

    // ==========================================
    // 9. Datapath Updates (NO RESET) 
    // ==========================================
    always @(posedge clk) begin
        // Weights Loading
        if (state == S_IDLE && i_valid && !weight_loaded) w_conv_dn[0][0] <= i_weight;
        else if (state == S_LOAD_W && i_valid) begin
            if (load_cnt < 144)       w_conv_dn[w_ch][w_idx] <= i_weight;
            else if (load_cnt < 400)  w_q[w_ch][w_idx] <= i_weight;
            else if (load_cnt < 656)  w_k[w_ch][w_idx] <= i_weight;
            else if (load_cnt < 912)  w_v[w_ch][w_idx] <= i_weight;
            else if (load_cnt < 1168) w_ffn[w_ch][w_idx] <= i_weight;
            else                      w_conv_up[w_ch][w_idx] <= i_weight;
        end

        if (state == S_LOAD_IMG && i_valid) img_DI <= {i_data, img_DI[31:8]};
        else if (state == S_IDLE && i_valid && weight_loaded) img_DI <= {i_data, 24'd0};
        else if (state == S_INTERP && step_cnt == 4) img_DI <= {out_word_comb[3], out_word_comb[2], out_word_comb[1], out_word_comb[0]};

        // CONV DOWN Datapath
        if (state == S_CONV_DOWN) begin
            if (step_cnt == 0) for (i=0; i<16; i=i+1) mac_acc[i] <= 0;
            else if (step_cnt >= 2 && step_cnt <= 10) begin
                for (i = 0; i < 16; i = i + 1) begin
                    for (j=0; j<8; j=j+1) w_conv_dn[i][j] <= w_conv_dn[i][j+1];
                    w_conv_dn[i][8] <= w_conv_dn[i][0];
                end
            end
            if (step_cnt >= 3 && step_cnt <= 11) begin
                for (i = 0; i < 16; i = i + 1) if (valid_dn_d3) mac_acc[i] <= mac_acc[i] + P1_reg[i][0];
            end
        end

        // CONV UP Datapath
        if (state == S_CONV_UP) begin
            if (step_cnt == 0) mac_acc[0] <= 0;
            else if (step_cnt >= 2 && step_cnt <= 10) begin
                for (i = 0; i < 16; i = i + 1) begin
                    for (j=0; j<8; j=j+1) w_conv_up[i][j] <= w_conv_up[i][j+1];
                    w_conv_up[i][8] <= w_conv_up[i][0];
                end
            end
            if (step_cnt >= 3 && step_cnt <= 11) begin
                if (valid_up_d3) mac_acc[0] <= mac_acc[0] + Tree1_out[0];
            end
        end

        // fmA_DI (Feature Map A SRAM Data Input)
        if (state == S_CONV_DOWN && step_cnt == 12) 
            fmA_DI <= { out_clip_array[15], out_clip_array[14], out_clip_array[13], out_clip_array[12], out_clip_array[11], out_clip_array[10], out_clip_array[9], out_clip_array[8], out_clip_array[7], out_clip_array[6], out_clip_array[5], out_clip_array[4], out_clip_array[3], out_clip_array[2], out_clip_array[1], out_clip_array[0] };
        else if (state == S_QKV && step_cnt == 9) 
            fmA_DI <= qkv_out_buf;
        else if (state == S_ATTN && step_cnt >= 278 && step_cnt <= 293) begin
            for (i=0; i<16; i=i+1) begin
                if ((v_acc[step_cnt - 278][i] >>> 16) > 25'sd127)       fmA_DI[i*8+:8] <= 8'd127;
                else if ((v_acc[step_cnt - 278][i] >>> 16) < -25'sd128) fmA_DI[i*8+:8] <= -8'd128;
                else fmA_DI[i*8+:8] <= v_acc[step_cnt - 278][i][23:16]; 
            end
        end
        else if (state == S_CONV_UP && step_cnt == 12) 
            fmA_DI <= {120'd0, out_clip_array[0]};

        // fmB_DI (Feature Map B SRAM Data Input)
        if (state == S_QKV && step_cnt == 5) fmB_DI <= qkv_out_buf;
        else if (state == S_QKV && step_cnt == 7) fmB_DI <= qkv_out_buf;
        else if (state == S_FFN && step_cnt == 5) fmB_DI <= qkv_out_buf;

        // Shared Target Registers
        if (state == S_QKV) begin
            if (step_cnt == 2) X_reg <= fmA_DO;
            if (step_cnt == 4) qkv_out_buf <= comb_qkv_data;
            if (step_cnt == 6) qkv_out_buf <= comb_qkv_data;
            if (step_cnt == 8) qkv_out_buf <= comb_qkv_data;
        end
        if (state == S_FFN) begin
            if (step_cnt == 2) X_reg <= fmA_DO;
            if (step_cnt == 4) qkv_out_buf <= comb_ffn_data;
        end

        // ATTENTION Massive Parallel Data Core
        if (state == S_ATTN) begin
            if (step_cnt >= 2 && step_cnt <= 17) attn_Q_buf[step_cnt - 2] <= fmB_DO;
            if (step_cnt >= 18 && step_cnt <= 273) begin K_data_reg <= fmB_DO; V_data_reg <= fmA_DO; end
            if (step_cnt >= 19 && step_cnt <= 274) V_d1 <= V_data_reg;
            if (step_cnt >= 20 && step_cnt <= 275) begin
                for(i=0; i<16; i=i+1) fixed_reg[i] <= comb_fixed[i];
                V_d2 <= V_d1;
            end
            
            if (step_cnt == 0) begin
                for(i=0; i<16; i=i+1) for(j=0; j<16; j=j+1) v_acc[i][j] <= 0;
            end
            else if (step_cnt >= 22 && step_cnt <= 277) begin
                for(i=0; i<16; i=i+1) begin
                    for(j=0; j<16; j=j+1) begin
                        v_acc[i][j] <= v_acc[i][j] + P2_reg[i][j];
                    end
                end
            end
        end

        // INTERP Reconstruct Datapath
        if (state == S_INTERP) begin
            if (step_cnt == 2) val_A <= fmA_DO[7:0];
            if (step_cnt == 3) begin val_B <= fmA_DO[7:0]; orig_word <= img_DO; end
            if (step_cnt == 4) out_word_reg <= {out_word_comb[3], out_word_comb[2], out_word_comb[1], out_word_comb[0]};
        end
    end

